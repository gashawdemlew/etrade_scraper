# Example environment variables for eTrade Scraper
# Set DATABASE_URL to your Postgres/DB instance. If not provided, sqlite file ./data/app.db is used.
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/etrade_db

# For quick local testing only: disable SSL verification (not recommended for prod)
# ETRADE_INSECURE=1

# App host/port
APP_HOST=0.0.0.0
APP_PORT=8011
